---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

// 1. Fetch the latest 3 projects for the homepage "Work" section
const projects = await sanityClient.fetch(`*[_type == "project"] | order(_createdAt desc) [0...3]`);
const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) { return builder.image(source); }
---

<BaseLayout title="Strategic Branding & Web Design Agency | Inkbot Design">
	
	<section class="hero-section py-5 my-5">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-8">
					<h1 class="display-1 fw-bold tracking-tight mb-4">
						Strategic Branding & <br/> <span class="text-outline">Web Design Agency</span>
					</h1>
					<p class="lead fs-3 mb-5 text-secondary" style="max-width: 700px;">
						We help ambitious businesses scale through world-class brand identity, 
						high-performance web design, and technical SEO excellence.
					</p>
					<div class="d-flex gap-3">
						<a href="/request-a-quote" class="btn btn-dark btn-lg px-5 py-3 rounded-pill">Start a Project</a>
						<a href="/work" class="btn btn-outline-dark btn-lg px-5 py-3 rounded-pill">View Work</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-light py-5">
		<div class="container py-5">
			<div class="row g-4">
				<div class="col-md-4">
					<div class="service-card p-4 h-100">
						<h3 class="fw-bold">Branding</h3>
						<p>Logo design, brand strategy, and visual identity systems that command attention.</p>
					</div>
				</div>
				<div class="col-md-4">
					<div class="service-card p-4 h-100">
						<h3 class="fw-bold">Web Design</h3>
						<p>Bespoke Astro & WordPress development optimized for speed, UX, and conversion.</p>
					</div>
				</div>
				<div class="col-md-4">
					<div class="service-card p-4 h-100">
						<h3 class="fw-bold">SEO</h3>
						<p>Technical and semantic SEO strategies designed to dominate Search in 2026.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-5">
		<div class="container py-5">
			<div class="d-flex justify-content-between align-items-end mb-5">
				<h2 class="display-4 fw-bold">Featured Work</h2>
				<a href="/work" class="text-decoration-none fw-bold text-dark">View All Projects →</a>
			</div>
			
			<div class="row g-4">
				{projects.map((project) => (
					<div class="col-md-4">
						<a href={`/work/${project.slug.current}`} class="text-decoration-none text-dark group">
							<div class="overflow-hidden rounded-4 mb-3">
								<img 
									src={urlFor(project.mainImage).width(800).height(600).url()} 
									alt={project.title}
									class="img-fluid transition-transform"
								/>
							</div>
							<h4 class="fw-bold">{project.title}</h4>
							<p class="text-muted">{project.services?.join(' / ')}</p>
						</a>
					</div>
				))}
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	.text-outline {
		-webkit-text-stroke: 1px #000;
		color: transparent;
	}
	.service-card {
		border: 1px solid #ddd;
		transition: all 0.3s ease;
	}
	.service-card:hover {
		background: #000;
		color: #fff;
	}
	.transition-transform {
		transition: transform 0.5s ease;
	}
	.group:hover .transition-transform {
		transform: scale(1.05);
	}
</style>