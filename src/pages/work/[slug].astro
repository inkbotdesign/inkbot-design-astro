---
// src/pages/work/[slug].astro
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext"; // Updated import
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  // Fetch all slugs from Sanity
  const projects = await sanityClient.fetch(`*[_type == "project" && defined(slug.current)]`);

  return projects.map((project) => ({
    params: { slug: project.slug.current },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Inkbot Design`}>
  <main class="container py-5">
    <h1 class="display-3 mb-4">{project.title}</h1>
    
    <div class="prose max-w-none">
      <PortableText value={project.body} />
    </div>
  </main>
</Layout>