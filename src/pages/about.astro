---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="About Our Agency" 
	description="Inkbot Design is a strategic branding agency based in Belfast, partnering with global clients to build market-leading brands."
>
	<section class="page-header">
		<div class="container">
			<h1>About Inkbot Design</h1>
			<p class="lead">We don't just design logos; we build strategic brand architectures.</p>
		</div>
	</section>

	<section class="content-section">
		<div class="container">
			<h2>Based in Belfast, Operating Globally</h2>
			<p>For over a decade, we have partnered with ambitious businesses to craft identities that resonate and websites that convert. Our approach marries data-driven strategy with high-end creative execution.</p>
			
			<h3>Our Core Values</h3>
			<ul>
				<li><strong>Strategic First:</strong> Every design decision is backed by business goals.</li>
				<li><strong>Technical Excellence:</strong> We build lightning-fast, accessible, and scalable digital products.</li>
				<li><strong>Partnership:</strong> We work collaboratively as an extension of your internal team.</li>
			</ul>
		</div>
	</section>
</BaseLayout>