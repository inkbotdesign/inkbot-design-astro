---
import { sanityClient } from 'sanity:client';

// Fetch just the titles of your projects
const projects = await sanityClient.fetch(`*[_type == "project"]{title}`);
---

<h1>Sanity Connection Test</h1>
{projects.length > 0 ? (
  <ul>
    {projects.map((p) => <li>Found Project: {p.title}</li>)}
  </ul>
) : (
  <p>Connected, but no projects found. Make sure you hit 'Publish' in the Studio!</p>
)}